# Copy this file to .env.local for development, or set these as environment
# variables in your hosting provider's dashboard for production.
# Every variable here is optional — the site builds and runs correctly with
# none of them set. They exist to turn on specific production integrations.

# --- Site identity -----------------------------------------------------
# Overrides src/lib/site-config.ts's hardcoded url if you deploy to a
# different domain (staging, a preview URL, etc). Leave unset in production
# once ismaelads.com is live and site-config.ts's url matches it.
# NEXT_PUBLIC_SITE_URL=https://www.ismaelads.com

# --- Analytics -----------------------------------------------------------
# Google Analytics 4 measurement ID (starts with "G-"). Analytics is fully
# disabled — no script tags render at all — until this is set. See
# src/components/common/google-analytics.tsx.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Search engine verification -------------------------------------------
# Google Search Console: Settings > Ownership verification > HTML tag method,
# copy just the "content" value (not the whole meta tag).
# GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: Settings > Verify ownership > HTML meta tag method,
# copy just the "content" value.
# BING_SITE_VERIFICATION=
